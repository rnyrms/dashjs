{
  "name": "dashjs",
  "version": "0.1.0",
  "description": "Framework-agnostic survey dashboard component built on the Jspreadsheet stack (LemonadeJS + jSuites + Jspreadsheet) with Highcharts and Lucide.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles": "./src/styles/dashjs.css"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "dashboard",
    "data-visualization",
    "charts",
    "jspreadsheet",
    "lemonadejs",
    "jsuites",
    "highcharts",
    "framework-agnostic",
    "vanilla-js",
    "typescript"
  ],
  "author": "Rony",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rnyrms/dashjs.git"
  },
  "bugs": {
    "url": "https://github.com/rnyrms/dashjs/issues"
  },
  "homepage": "https://github.com/rnyrms/dashjs#readme",
  "peerDependencies": {
    "gridstack": "^12.0.0",
    "highcharts": "^12.0.0",
    "jspreadsheet": "^12.0.0",
    "jsuites": "^6.0.0",
    "lemonadejs": "^5.0.0",
    "lucide": "^0.460.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.8",
    "gridstack": "^12.6.0",
    "highcharts": "^12.5.0",
    "jsdom": "^29.1.1",
    "jspreadsheet": "^12.3.0",
    "jsuites": "^6.0.0",
    "lemonadejs": "^5.3.6",
    "lucide": "^0.460.0",
    "tabularjs": "^1.0.1",
    "typescript": "~5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  }
}
